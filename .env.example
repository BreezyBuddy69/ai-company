# Copy to .env and fill in. Nothing here is required to build the stack;
# OPENROUTER_API_KEY is required before any agent can actually think.

# --- Postgres ---
POSTGRES_USER=factory
POSTGRES_PASSWORD=changeme-strong-password
POSTGRES_DB=factory

# --- Edge auth ---
# Required. The dashboard sends this as X-API-Key to the backend on every
# call (baked into its JS bundle at build time — see docker-compose.yml).
# Generate one: openssl rand -hex 24
API_KEY=

# --- Dashboard login (HTTP Basic Auth) ---
# Gates the whole dashboard site (dashboard/middleware.ts) — same mechanism
# whether you're running `next dev` locally, the Hostinger open deploy, or
# behind Traefik. Blank = open (fine for local-only testing). Rotate anytime
# by changing these and restarting the dashboard container — no rebuild
# needed, unlike API_KEY.
DASHBOARD_USER=
DASHBOARD_PASSWORD=

# --- Model router (free-first — see model_registry.yaml) ---
# Get a free key at https://openrouter.ai/keys — no payment method required
# to use the :free models this system is built around.
OPENROUTER_API_KEY=

# --- Scout data sources ---
# Optional: raises the GitHub issue-search rate limit from 60/hr to 5000/hr.
# A classic PAT with no scopes selected is enough (public read-only search).
GITHUB_TOKEN=
# Comma-separated pain-point keywords the Scout agent searches for.
SCOUT_KEYWORDS=expensive,manual,tedious,frustrating,workaround,spreadsheet hell,no good tool

# --- Dashboard ---
# The URL a BROWSER can reach — not the in-Docker-network "backend" hostname.
# Deploying on the shared halovisionai.cloud VPS (see DEPLOY.md): leave this
# commented out, docker-compose.yml already defaults it to
# https://factory-api.halovisionai.cloud (the Traefik-routed backend).
# Testing purely locally with `docker compose up` and no Traefik: uncomment
# and point at the direct port instead.
# DASHBOARD_PUBLIC_API_URL=http://localhost:47832

# --- n8n ---
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme-strong-password
# Same story as above: on the VPS, leave these commented out (compose
# defaults to factory-n8n.halovisionai.cloud / https). Local-only testing:
# N8N_HOST=localhost
# N8N_PROTOCOL=http
TZ=UTC

# --- Backend misc ---
LOG_LEVEL=INFO
ENVIRONMENT=production
